# Production Environment Configuration
# Copy this file to .env and fill in with actual production values

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=8000

# !!!IMPORTANT!!! Generate a strong secret key for production
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-key

# Email Configuration (for contact form notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_production_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
ADMIN_EMAIL=admin@yourproductionsite.com

# Optional: Hugging Face Configuration (for free AI models)
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: Database URL (for production database connections)
# DATABASE_URL=sqlite:///data/film_production.db
